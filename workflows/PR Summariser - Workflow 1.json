    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet diffString = \"\";\nlet truncated = false;\nconst MAX_CHARS = 6000;\n\nfor (const item of items) {\n  const filename = item.json.filename || \"unknown file\";\n  const patch = item.json.patch || \"(binary or empty file — no diff available)\";\n  const block = `File: ${filename}\\n${patch}\\n\\n`;\n\n  if ((diffString + block).length > MAX_CHARS) {\n    truncated = true;\n    break;\n  }\n\n  diffString += block;\n}\n\nif (truncated) {\n  diffString += `\\n[Note: diff truncated — some files not shown due to size limits]`;\n}\n\nconst first = items[0].json;\n\nreturn [{\n  json: {\n    diff_string: diffString,\n    pr_title: first.pr_title,\n    pr_author: first.pr_author,\n    pr_number: first.pr_number,\n    pr_body: first.pr_body || \"No description provided\",\n    repo_name: first.repo_name,\n    repo_owner: first.repo_owner,\n    truncated: truncated\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        880,
        0
      ],
      "id": "7cb102e8-e0ab-4a9e-90ce-89ae9b20f466",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://openrouter.ai/api/v1/chat/completions",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer YOUR_OPENROUTER_KEY
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "HTTP-Referer",
              "value": "https://n8n.io"
            },
            {
              "name": "X-Title",
              "value": "PR Bot"
            }
          ]
        },
        "sendBody": true,
        "contentType": "raw",
        "rawContentType": "application/json",
        "body": "={{ $json.request_body }}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.4,
      "position": [
        1296,
        0
      ],
      "id": "6ce99c84-75ce-464b-b296-035828aab0bd",
      "name": "HTTP Request"
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\n\nconst prompt = `Review this PR and return ONLY valid JSON, no markdown fences.\n\nPR Title: ${data.pr_title}\nAuthor: ${data.pr_author}\n\nChanged files:\n${data.diff_string}\n\nReturn exactly:\n{\"summary\":\"2-3 sentence summary\",\"key_changes\":[\"change 1\"],\"concerns\":[],\"complexity\":\"low or medium or high\",\"suggestion\":\"one improvement\"}`;\n\nreturn [{\n  json: {\n    ...data,\n    request_body: JSON.stringify({\n      model: \"openai/gpt-oss-20b:free\",\n      max_tokens: 500,\n      messages: [{ role: \"user\", content: prompt }]\n    })\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1088,
        0
      ],
      "id": "f09384d9-ba41-46bb-981a-8a4a6274489d",
      "name": "Build Request Body"
    },
    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\n\n// Extract content from OpenRouter response\nlet text = response.choices[0].message.content;\n\n// Strip markdown fences just in case\ntext = text.replace(/```json|```/g, '').trim();\n\n// Parse the review JSON\nlet review;\ntry {\n  review = JSON.parse(text);\n} catch (e) {\n  review = {\n    summary: \"Could not parse AI response\",\n    key_changes: [],\n    concerns: [],\n    complexity: \"unknown\",\n    suggestion: text\n  };\n}\n\n// Complexity emoji\nconst complexityEmoji = {\n  low: \"🟢\",\n  medium: \"🟡\", \n  high: \"🔴\",\n  unknown: \"⚪\"\n};\n\n// Build markdown comment\nconst emoji = complexityEmoji[review.complexity] || \"⚪\";\n\nconst keyChanges = review.key_changes.length > 0\n  ? review.key_changes.map(c => `- ${c}`).join(\"\\n\")\n  : \"- No major changes detected\";\n\nconst concerns = review.concerns.length > 0\n  ? review.concerns.map(c => `- ⚠️ ${c}`).join(\"\\n\")\n  : \"- ✅ No concerns found\";\n\nconst comment = `## 🤖 AI Code Review\n\n**Summary**\n${review.summary}\n\n**Key Changes**\n${keyChanges}\n\n**Concerns**\n${concerns}\n\n**Complexity:** ${emoji} ${review.complexity}\n\n**Suggestion**\n💡 ${review.suggestion}\n\n---\n*Reviewed automatically by PR Bot · Powered by n8n + OpenRouter*`;\n\n// Pass forward with PR metadata\nconst upstream = $('Build Request Body').first().json;\n\nreturn [{\n  json: {\n    comment,\n    pr_number: upstream.pr_number,\n    repo_name: upstream.repo_name,\n    repo_owner: upstream.repo_owner\n  }\n}];"
      },
